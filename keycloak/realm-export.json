      "realmRoles": ["USER", "Accounts", "Cash", "Transfer", "Notifications"]
    },
    {
      "username": "petrov",
      "firstName": "Петр",
      "lastName": "Петров",
      "email": "petrov@bank.local",
      "enabled": true,
      "emailVerified": true,
      "credentials": [{"type": "password", "value": "password", "temporary": false}],
      "realmRoles": ["USER", "Accounts", "Cash", "Transfer", "Notifications"]
    },
    {
      "username": "sidorov",
      "firstName": "Сидор",
      "lastName": "Сидоров",
      "email": "sidorov@bank.local",
      "enabled": true,
      "emailVerified": true,
      "credentials": [{"type": "password", "value": "password", "temporary": false}],
      "realmRoles": ["USER", "Accounts", "Cash", "Transfer", "Notifications"]
    },
    {
      "username": "service-account-microservices-client",
      "enabled": true,
      "serviceAccountClientId": "microservices-client",
      "realmRoles": ["MICROSERVICE"]
    }
  ]
}
