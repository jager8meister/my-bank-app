# =============================================================
#  Скопируйте этот файл в .env и заполните значения.
#  cp .env.example .env
# =============================================================

# -------------------------------------------------------------
# PostgreSQL
# -------------------------------------------------------------
POSTGRES_DB=bankdb
POSTGRES_USER=bankuser
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=5432
POSTGRES_INITDB_ARGS=--encoding=UTF8 --locale=ru_RU.UTF-8

# -------------------------------------------------------------
# Keycloak
# -------------------------------------------------------------
KEYCLOAK_PORT=9090
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=changeme
KEYCLOAK_REALM=bank-realm
KEYCLOAK_DB_SCHEMA=keycloak_schema
KEYCLOAK_THEME=bank-theme
# Keycloak не публикует порты наружу — доступен только внутри Docker-сети.

# Hostname Keycloak (только хост, без схемы и порта).
# Используется в JWT как часть issuer. Должен совпадать с хостом в KEYCLOAK_EXTERNAL_URL.
KEYCLOAK_HOSTNAME=localhost

# URL Keycloak для браузера (снаружи Docker)
KEYCLOAK_EXTERNAL_URL=http://localhost:9090

# URL Keycloak для межсервисного взаимодействия (внутри Docker)
KEYCLOAK_INTERNAL_URL=http://keycloak:9090

# -------------------------------------------------------------
# OAuth2 Client Secrets
#
# Должны совпадать со значениями в keycloak/realm-export.json.
# При смене секретов — пересоздайте БД (docker compose down -v),
# обновите realm-export.json и запустите заново.
# -------------------------------------------------------------
MICROSERVICES_CLIENT_SECRET=microservices-secret-key-12345
FRONT_CLIENT_SECRET=front-client-secret-key-67890
GATEWAY_CLIENT_SECRET=gateway-client-secret-key-11111

# -------------------------------------------------------------
# Порты сервисов
# Можно менять если стандартные порты заняты.
# -------------------------------------------------------------
GATEWAY_PORT=8080
ACCOUNTS_SERVICE_PORT=8081
CASH_SERVICE_PORT=8082
AUTH_SERVICE_PORT=8083
FRONT_SERVICE_PORT=8084
TRANSFER_SERVICE_PORT=8085
NOTIFICATIONS_SERVICE_PORT=8086
