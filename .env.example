# PostgreSQL Database Configuration
POSTGRES_DB=bankdb
POSTGRES_USER=bankuser
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_PORT=5432

# Keycloak Configuration
KEYCLOAK_PORT=9090
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
KEYCLOAK_EXTERNAL_URL=http://localhost:9090
KEYCLOAK_INTERNAL_URL=http://keycloak:9090

# OAuth2 Client Secrets
# IMPORTANT: Generate strong random secrets for production!
# You can use: openssl rand -base64 32
MICROSERVICES_CLIENT_SECRET=CHANGE_ME_GENERATE_RANDOM_SECRET
FRONT_CLIENT_SECRET=CHANGE_ME_GENERATE_RANDOM_SECRET
GATEWAY_CLIENT_SECRET=CHANGE_ME_GENERATE_RANDOM_SECRET

# Database Password (same as POSTGRES_PASSWORD for this setup)
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Service Ports
CONFIG_SERVER_PORT=8888
EUREKA_SERVER_PORT=8761
GATEWAY_PORT=8080
ACCOUNTS_SERVICE_PORT=8081
CASH_SERVICE_PORT=8082
AUTH_SERVICE_PORT=8083
TRANSFER_SERVICE_PORT=8085
NOTIFICATIONS_SERVICE_PORT=8086
FRONT_SERVICE_PORT=8084
